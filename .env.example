# Map-Service database
MAP_DB_USER=postgres
MAP_DB_PASSWORD=postgres
MAP_DB_NAME=rua_map

# WaitTime-Service database
WAITTIME_DB_USER=postgres
WAITTIME_DB_PASSWORD=postgres
WAITTIME_DB_NAME=rua_waittime

# MQTT broker credentials used by services and broker healthchecks
MQTT_USER=services
MQTT_PASS=replace-with-a-real-mqtt-password

# Optional shared application key used by some services
API_KEY=replace-with-a-real-api-key
